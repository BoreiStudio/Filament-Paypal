{
    "name": "boreistudio/filament-paypal",
    "type": "library",
    "description": "Filament plugin for PayPal integration — Orders, Payments, Subscriptions, Webhooks, Payouts",
    "keywords": ["filament", "paypal", "laravel"],
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "illuminate/contracts": "^12.0|^13.0",
        "filament/filament": "^5.0",
        "paypal/paypal-server-sdk": "^2.3",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-settings": "^3.0"
    },
    "require-dev": {
        "laravel/framework": "^12.0|^13.0",
        "orchestra/testbench": "^10.0|^11.0",
        "laravel/pint": "^1.0",
        "larastan/larastan": "^3.0",
        "pestphp/pest": "^4.7",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "BoreiStudio\\FilamentPayPal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BoreiStudio\\FilamentPayPal\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BoreiStudio\\FilamentPayPal\\PayPalServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
